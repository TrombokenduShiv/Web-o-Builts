# Backend Environment Variables
# Copy this to .env and fill in real values

DJANGO_SECRET_KEY=change-me-to-a-random-string-at-least-50-chars
DEBUG=False
DATABASE_URL=postgres://user:password@hostname/dbname
ALLOWED_HOSTS=webobuilts-api.onrender.com,localhost,127.0.0.1

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-dashboard.vercel.app,https://your-landing.vercel.app
CSRF_TRUSTED_ORIGINS=https://webobuilts-api.onrender.com

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# Google Sheets Sync
TARGET_SPREADSHEET_ID=your-google-sheet-id
GOOGLE_CREDENTIALS_BASE64=base64-encoded-service-account-json

# Google OAuth (for Sign in with Google)
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxxx
GOOGLE_OAUTH_CALLBACK_URL=https://your-dashboard.vercel.app

# Email (for OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Web-o-Builts <your-email@gmail.com>

# Frontend URL (for redirects)
FRONTEND_DASHBOARD_URL=https://your-dashboard.vercel.app
